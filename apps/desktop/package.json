{
  "name": "@rough-cut/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/main/index.mjs",
  "scripts": {
    "dev": "concurrently \"vite --host 127.0.0.1 --port 7544\" \"wait-on http://127.0.0.1:7544 && ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .\"",
    "dev:minimal": "ROUGH_CUT_MINIMAL_BOOT=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .",
    "dev:minimal-render": "concurrently \"vite --host 127.0.0.1 --port 7544\" \"wait-on http://127.0.0.1:7544 && ROUGH_CUT_MINIMAL_RENDER=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .\"",
    "dev:import-app-only": "concurrently \"vite --host 127.0.0.1 --port 7544\" \"wait-on http://127.0.0.1:7544 && ROUGH_CUT_IMPORT_APP_ONLY=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .\"",
    "dev:shell-only": "concurrently \"vite --host 127.0.0.1 --port 7544\" \"wait-on http://127.0.0.1:7544 && ROUGH_CUT_SHELL_ONLY=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .\"",
    "dev:record-shell-only": "concurrently \"vite --host 127.0.0.1 --port 7544\" \"wait-on http://127.0.0.1:7544 && ROUGH_CUT_RECORD_SHELL_ONLY=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .\"",
    "dev:record-ultra-minimal": "concurrently \"vite --host 127.0.0.1 --port 7544\" \"wait-on http://127.0.0.1:7544 && ROUGH_CUT_RECORD_ULTRA_MINIMAL=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .\"",
    "dev:record-store-only": "concurrently \"vite --host 127.0.0.1 --port 7544\" \"wait-on http://127.0.0.1:7544 && ROUGH_CUT_RECORD_STORE_ONLY=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .\"",
    "dev:record-runtime-hooks": "concurrently \"vite --host 127.0.0.1 --port 7544\" \"wait-on http://127.0.0.1:7544 && ROUGH_CUT_RECORD_RUNTIME_HOOKS=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .\"",
    "dev:record-chrome-only": "concurrently \"vite --host 127.0.0.1 --port 7544\" \"wait-on http://127.0.0.1:7544 && ROUGH_CUT_RECORD_CHROME_ONLY=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .\"",
    "dev:record-workspace-only": "concurrently \"vite --host 127.0.0.1 --port 7544\" \"wait-on http://127.0.0.1:7544 && ROUGH_CUT_RECORD_WORKSPACE_ONLY=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .\"",
    "dev:record-only": "concurrently \"vite --host 127.0.0.1 --port 7544\" \"wait-on http://127.0.0.1:7544 && ROUGH_CUT_START_TAB=record ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .\"",
    "dev:swiftshader": "concurrently \"vite --host 127.0.0.1 --port 7544\" \"wait-on http://127.0.0.1:7544 && ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --disable-gpu --disable-gpu-compositing --in-process-gpu --use-angle=swiftshader --use-gl=swiftshader --force-color-profile=srgb .\"",
    "dev:vite": "vite",
    "dev:electron": "electron --force-color-profile=srgb .",
    "dev:electron:reuse": "wait-on http://127.0.0.1:7544 && ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .",
    "dev:minimal-render:reuse": "wait-on http://127.0.0.1:7544 && ROUGH_CUT_MINIMAL_RENDER=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .",
    "dev:import-app-only:reuse": "wait-on http://127.0.0.1:7544 && ROUGH_CUT_IMPORT_APP_ONLY=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .",
    "dev:shell-only:reuse": "wait-on http://127.0.0.1:7544 && ROUGH_CUT_SHELL_ONLY=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .",
    "dev:record-ultra-minimal:reuse": "wait-on http://127.0.0.1:7544 && ROUGH_CUT_RECORD_ULTRA_MINIMAL=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .",
    "dev:record-shell-only:reuse": "wait-on http://127.0.0.1:7544 && ROUGH_CUT_RECORD_SHELL_ONLY=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .",
    "dev:record-chrome-only:reuse": "wait-on http://127.0.0.1:7544 && ROUGH_CUT_RECORD_CHROME_ONLY=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .",
    "dev:record-workspace-only:reuse": "wait-on http://127.0.0.1:7544 && ROUGH_CUT_RECORD_WORKSPACE_ONLY=1 ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .",
    "dev:record-only:reuse": "wait-on http://127.0.0.1:7544 && ROUGH_CUT_START_TAB=record ROUGH_CUT_SKIP_AUDIO_DISCOVERY=1 electron --no-sandbox --force-color-profile=srgb .",
    "build": "vite build",
    "test": "node --test src/shared/recording-pause-policy.test.mjs && vitest run src/renderer/components/cursor-overlay-state.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@remotion/core": "1.0.0-y.46",
    "@remotion/player": "^4.0.441",
    "@rough-cut/effect-registry": "workspace:*",
    "@rough-cut/export-renderer": "workspace:*",
    "@rough-cut/frame-resolver": "workspace:*",
    "@rough-cut/preview-renderer": "workspace:*",
    "@rough-cut/project-model": "workspace:*",
    "@rough-cut/store": "workspace:*",
    "@rough-cut/timeline-engine": "workspace:*",
    "electron-store": "^11.0.2",
    "mediabunny": "^1.40.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "electron": "^35.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.0"
  }
}
