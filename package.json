{
  "name": "rough-cut",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:e2e": "xvfb-run --auto-servernum playwright test",
    "test:e2e:headless": "xvfb-run --auto-servernum playwright test",
    "test:e2e:headless:serial": "xvfb-run --auto-servernum playwright test --workers=1",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:headed:serial": "playwright test --headed --workers=1",
    "typecheck": "turbo run typecheck",
    "logs:app": "tail -F .logs/app-runtime.log",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "playwright": "^1.58.2",
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "uiohook-napi": "^1.5.5"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
