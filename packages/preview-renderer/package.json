{
  "name": "@rough-cut/preview-renderer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@rough-cut/effect-registry": "workspace:*",
    "@rough-cut/frame-resolver": "workspace:*",
    "@rough-cut/project-model": "workspace:*",
    "mediabunny": "^1.40.1",
    "mp4box": "^2.3.0",
    "pixi.js": "^8.6.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
