{
  "name": "@rough-cut/export-renderer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./webcodecs": {
      "types": "./dist/webcodecs.d.ts",
      "import": "./dist/webcodecs.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no lint configured yet'",
    "clean": "rm -rf dist *.tsbuildinfo",
    "demo": "tsx src/demo.ts"
  },
  "dependencies": {
    "@rough-cut/project-model": "workspace:*",
    "@rough-cut/frame-resolver": "workspace:*",
    "@rough-cut/effect-registry": "workspace:*",
    "canvas": "^3.1.0",
    "mediabunny": "^1.40.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "tsx": "^4.0.0"
  }
}
